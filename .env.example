# Required
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional but strongly recommended (single allowed chat/user)
ALLOWED_CHAT_ID=
ALLOWED_USER_IDS=

# Directory the bot is allowed to read/write
# If relative, it is resolved from project root.
FILE_ROOT=./memory

# Optional logging verbosity: info | debug
LOG_LEVEL=info

# Agent endpoint called for non-slash messages (and /agent)
ENABLE_AGENT_ROUTING=true
AGENT_ENDPOINT_URL=http://127.0.0.1:8787/agent/turn

# Local test chat mode (no Telegram)
LOCAL_CHAT_ID=local-test
LOCAL_CHAT_SHOW_RAW=false

# Agent memory root (skills can read from subfolders here)
MEMORY_ROOT=./memory

# Data skill root (optional override). If unset, defaults to MEMORY_ROOT/data
DATAFILES_ROOT=

# Persistent state root (sessions + event queue context)
STATE_ROOT=./state

# Model used by the generic agent router/composer
CODEX_MODEL=gpt-5.2-codex
# OPENAI_API_KEY=sk-...

# Agent server bind
AGENT_HOST=127.0.0.1
AGENT_PORT=8787
